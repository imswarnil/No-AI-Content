# --- Database (Neon / Vercel Postgres / any Postgres) ---
# Get this from Neon (neon.tech) or the Vercel Postgres integration.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Admin dashboard ---
# A secret token you choose. Required to view the tracking dashboard at /dashboard.
ADMIN_TOKEN="change-me-to-a-long-random-string"
