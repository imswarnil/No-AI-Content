# --- Database (Neon / Vercel Postgres / any Postgres) ---
# Get this from Neon (neon.tech) or the Vercel Postgres integration.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Admin dashboard ---
# A secret token you choose. Required to view the tracking dashboard at /dashboard.
ADMIN_TOKEN="change-me-to-a-long-random-string"

# --- Public site URL (for SEO: canonical, sitemap, JSON-LD, Open Graph) ---
# Set to your deployed URL, e.g. https://no-ai-content.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- AI "human-ness" analyzer (/check) ---
# Anthropic API key. Get one at https://console.anthropic.com. Only needed for
# the /check page; the rest of the app runs without it.
ANTHROPIC_API_KEY="sk-ant-..."
